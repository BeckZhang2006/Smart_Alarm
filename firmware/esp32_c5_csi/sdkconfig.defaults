# WiFi CSI Configuration
CONFIG_ESP_WIFI_CSI_ENABLED=y
CONFIG_ESP_WIFI_CSI_CHANNEL_SCAN_INTERVAL_MS=100

# WiFi Configuration
CONFIG_ESP_WIFI_SSID="SmartAlarm_CSI"
CONFIG_ESP_WIFI_PASSWORD="12345678"

# UART Configuration for communication with WTDKP4C5-S1
CONFIG_UART_BAUDRATE=115200
CONFIG_UART_TX_PIN=5
CONFIG_UART_RX_PIN=4

# Detection Thresholds
CONFIG_PERSON_DETECT_THRESHOLD=30
CONFIG_CSI_SAMPLING_RATE=100

# Power Management
CONFIG_PM_ENABLE=y
